# Local dev environment variables (read by Astro/Vite from `.env`).
# Copy this file to ".env" and fill in real values. ".env" is gitignored —
# NEVER commit real keys. In production these are set in the Vercel dashboard
# (Project → Settings → Environment Variables), not here.

BREVO_API_KEY=your-brevo-api-key
BREVO_LIST_ID=4

# FUTURE — Zoom Server-to-Server OAuth (for webinar registration):
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_WEBINAR_ID=
