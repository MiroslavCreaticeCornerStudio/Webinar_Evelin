---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "INclusive — Безплатно онлайн обучение",
  description = "Психология на големите резултати. Безплатно онлайн обучение на живо — научете как се изграждат хора, които не могат да бъдат пренебрегнати.",
  ogImage = "/assets/images/og-image.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Scroll reveal: hide targets up-front (only if motion is OK), with a
         failsafe that restores visibility if the animation script never runs. -->
    <script is:inline>
      (function () {
        try {
          var mq = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)");
          if (mq && mq.matches) return;
          document.documentElement.classList.add("has-reveal");
          setTimeout(function () {
            if (!window.__revealReady) document.documentElement.classList.remove("has-reveal");
          }, 2500);
        } catch (e) {}
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="bg_BG" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Brand fonts: Le Havre (display) + Futura PT (body) via Adobe Fonts.
         Montserrat is kept as a Cyrillic-safety fallback. -->
    <link rel="stylesheet" href="https://use.typekit.net/fas0rfi.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link sr-only">Към съдържанието</a>
    <slot />

    <!-- Facebook Ads offline-conversion tracking: capture fbclid + UTMs from the
         ad URL and persist them so they can be attached to the form submission. -->
    <script>
      (function () {
        try {
          var KEYS = [
            "fbclid",
            "utm_source",
            "utm_medium",
            "utm_campaign",
            "utm_term",
            "utm_content",
          ];
          var params = new URLSearchParams(window.location.search);
          var store = JSON.parse(localStorage.getItem("inclusive_tracking") || "{}");
          var changed = false;
          KEYS.forEach(function (k) {
            var v = params.get(k);
            if (v) {
              store[k] = v;
              changed = true;
            }
          });
          if (params.get("fbclid")) {
            store.fb_click_time = Math.floor(Date.now() / 1000);
            store.landing_url = window.location.href;
            changed = true;
          }
          if (changed) localStorage.setItem("inclusive_tracking", JSON.stringify(store));
        } catch (e) {
          /* localStorage unavailable — ignore */
        }
      })();
    </script>
  </body>
</html>
