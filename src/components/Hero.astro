---
import Button from "./Button.astro";
import Countdown from "./Countdown.astro";
import { webinar } from "../data/webinar";

const infoItems = [
  { icon: "/assets/images/icon-calendar.svg", label: "Дата:", value: webinar.date },
  { icon: "/assets/images/icon-clock.svg", label: "Час:", value: webinar.time },
  { icon: "/assets/images/icon-mappin.svg", label: "Къде:", value: "Онлайн в Zoom" },
  { icon: "/assets/images/icon-hourglass.svg", label: "Времетраене:", value: "60 мин." },
];
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__left">
      <div class="hero__heading-block">
        <div class="hero__copy">
          <span class="hero__eyebrow">
            <img src="/assets/images/icon-eyebrow.svg" alt="" width="8" height="8" />
            Безплатно онлайн обучение на живо
          </span>

          <div class="hero__text">
            <div class="hero__title-wrap">
              <h1 class="hero__title">
                <span class="hero__title-1">Психология на големите резултати.</span>
                <span class="hero__title-2"
                  >Научете как се изграждат хора, които не могат да бъдат пренебрегнати.</span
                >
              </h1>
              <span class="divider-mark" aria-hidden="true"></span>
            </div>
            <p class="hero__desc">
              Опит право от бойното поле. Научи как правилната стратегия, сплотен екип и ясната
              посока могат да обърнат играта дори срещу най-големите конкуренти на имотния пазар.
            </p>
          </div>
        </div>

        <Button href="#cta" class="hero__cta">Запази своето място сега</Button>
      </div>

      <!-- Mobile-only countdown (in flow, between button and photo) -->
      <div class="hero__countdown-mobile">
        <Countdown />
      </div>

      <div class="hero__info">
        {
          infoItems.map((item) => (
            <div class="hero__info-item">
              <img src={item.icon} alt="" width="22" height="22" class="hero__info-icon" />
              <div class="hero__info-text">
                <span class="hero__info-label">{item.label}</span>
                <span class="hero__info-value">{item.value}</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="hero__media">
      <img src="/assets/images/hero-frame.svg" alt="" class="hero__frame" aria-hidden="true" />
      <img
        src="/assets/images/hero-speaker.webp"
        alt="Лектор на обучението INclusive"
        width="459"
        height="689"
        class="hero__photo"
      />
      <div class="hero__countdown">
        <Countdown />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-dark);
    overflow: hidden;
  }

  .hero__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2em;
  }

  .hero__left {
    display: flex;
    flex-direction: column;
    gap: 3.75em; /* 60px */
    width: 40.26em; /* 644px */
    padding-block: 4.0625em 0; /* top offset 65px */
  }

  .hero__heading-block {
    display: flex;
    flex-direction: column;
    gap: 2em; /* 32px */
    align-items: flex-start;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
  }

  /* Eyebrow */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    width: fit-content;
    padding: 0.5em 1em; /* 8px 16px */
    border: 1px solid var(--color-gold);
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1em; /* 16px */
    line-height: 1.3;
    color: var(--color-cream);
    text-transform: uppercase;
  }
  .hero__eyebrow img {
    width: 0.5em;
    height: 0.5em;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
  }

  .hero__title-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75em; /* 12px */
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    gap: 0.25em; /* 4px */
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .hero__title-1 {
    font-size: 3.5em; /* 56px */
    color: var(--color-gold);
  }
  .hero__title-2 {
    font-size: 2.25em; /* 36px */
    color: var(--color-cream);
  }

  .hero__desc {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.25em; /* 20px */
    line-height: 1.3;
    color: var(--color-cream);
  }

  /* Info bar */
  .hero__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5em;
    width: 100%;
    padding: 1.125em 1.5em 1.5em; /* 18 / 24 / 24 */
    background-color: rgba(57, 60, 70, 0.3);
    backdrop-filter: blur(7.5px);
    -webkit-backdrop-filter: blur(7.5px);
  }
  .hero__info-item {
    display: flex;
    gap: 0.375em; /* 6px */
    align-items: flex-start;
  }
  .hero__info-icon {
    width: 1.375em; /* 22px */
    height: 1.375em;
    flex-shrink: 0;
  }
  .hero__info-text {
    display: flex;
    flex-direction: column;
    gap: 0.288em; /* 4.61px */
    font-size: 1.25em; /* 20px */
    line-height: 1.1;
    color: var(--color-cream);
  }
  .hero__info-label {
    font-family: var(--font-body);
    font-weight: 300;
  }
  .hero__info-value {
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--color-cream); /* #f5f4ec */
  }

  /* Media (right) */
  .hero__media {
    position: relative;
    flex-shrink: 0;
    width: 31.1875em; /* 499px */
    height: 43.125em; /* 690px */
  }
  .hero__frame {
    position: absolute;
    left: 0;
    top: 4.75em; /* 76px */
    width: 31.1875em; /* 499px */
    height: 38.406em; /* 614.5px */
  }
  .hero__photo {
    position: absolute;
    left: 1.1875em; /* 19px */
    top: 0;
    width: 28.6875em; /* 459px */
    height: 43.0625em; /* 689px */
    object-fit: cover;
  }
  .hero__countdown {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 34.0625em; /* 545px */
  }

  /* In-flow countdown shown only on mobile (desktop uses the absolute one above) */
  .hero__countdown-mobile {
    display: none;
  }

  /* ---- Responsive ---- */
  @media (max-width: 991px) {
    .hero__inner {
      flex-direction: column;
      align-items: center;
      gap: 3em;
    }
    .hero__left {
      width: 100%;
      padding-block: 3em 0;
    }
    .hero__media {
      width: 31.1875em;
      max-width: 100%;
    }
  }

  /* ---- Mobile: match the dedicated mobile design ----
     Flatten the two columns and reorder to: heading → button → countdown →
     photo → info bar (per the Figma mobile layout). */
  @media (max-width: 767px) {
    .hero__inner {
      gap: 2em;
      padding-top: 2em;
    }
    /* Promote .hero__left's children into the column so everything reorders */
    .hero__left {
      display: contents;
    }
    .hero__heading-block {
      order: 1;
      width: 100%;
    }
    .hero__countdown-mobile {
      order: 2;
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .hero__media {
      order: 3;
    }
    .hero__info {
      order: 4;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25em 1em;
    }

    /* Eyebrow is omitted on mobile; heading is smaller */
    .hero__eyebrow {
      display: none;
    }
    .hero__title-1 {
      font-size: 2.25em; /* 36px */
    }
    .hero__title-2 {
      font-size: 1.25em; /* 20px */
    }
    .hero__desc {
      font-size: 1.125em; /* 18px */
    }

    /* The desktop (absolute, over-photo) countdown is replaced by the in-flow one */
    .hero__countdown {
      display: none;
    }
  }

  @media (max-width: 479px) {
    /* Scale the fixed-size media block down so it never exceeds the viewport */
    .hero__media {
      font-size: 0.6em;
    }
  }
</style>
