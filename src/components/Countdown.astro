---
import { webinar } from "../data/webinar";

interface Props {
  /** Webinar start, ISO-8601 with offset. Defaults to src/data/webinar.ts. */
  target?: string;
}

const { target = webinar.startISO } = Astro.props;

// Pre-JS placeholder values (overwritten on load by the script below).
const units = [
  { unit: "days", num: "06", label: "дни" },
  { unit: "hours", num: "04", label: "часа" },
  { unit: "minutes", num: "43", label: "минути" },
  { unit: "seconds", num: "12", label: "секунди" },
];
---

<div
  class="countdown"
  data-countdown
  data-target={target}
  role="timer"
  aria-label="Оставащо време до началото на обучението"
>
  {
    units.map((c) => (
      <div class="countdown__item">
        <div class="countdown__num" data-unit={c.unit}>
          {c.num}
        </div>
        <span class="countdown__label">{c.label}</span>
      </div>
    ))
  }
</div>

<style>
  .countdown {
    display: flex;
    gap: 0.6875em; /* 11px */
    align-items: center;
    width: fit-content;
    padding: 1em 1em 0.75em; /* 16 / 16 / 12 */
    background-color: var(--color-dark);
    border: 1px solid var(--color-gold);
  }
  .countdown__item {
    display: flex;
    flex-direction: column;
    gap: 0.6875em; /* 11px */
    align-items: center;
    justify-content: flex-end;
  }
  .countdown__num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.354em; /* 65px relative to this element's 48px font-size */
    padding-inline: 0.125em; /* 6px @48 */
    background-color: var(--color-surface);
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 3em; /* 48px */
    line-height: 1.2;
    color: var(--color-gold);
    text-transform: uppercase;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .countdown__label {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 0.875em; /* 14px */
    line-height: 1.1;
    color: var(--color-gray-40);
    text-transform: uppercase;
    text-align: center;
  }

  @media (max-width: 479px) {
    .countdown {
      padding: 0.75em;
    }
    .countdown__num {
      font-size: 2.25em;
    }
  }
</style>

<script>
  const pad = (n: number) => String(n).padStart(2, "0");

  document.querySelectorAll<HTMLElement>("[data-countdown]").forEach((el) => {
    const target = new Date(el.dataset.target ?? "").getTime();
    if (Number.isNaN(target)) return;

    const find = (u: string) => el.querySelector<HTMLElement>(`[data-unit="${u}"]`);
    const days = find("days");
    const hours = find("hours");
    const minutes = find("minutes");
    const seconds = find("seconds");

    let timer: ReturnType<typeof setInterval>;

    const tick = () => {
      const total = Math.max(0, Math.floor((target - Date.now()) / 1000));
      if (days) days.textContent = pad(Math.floor(total / 86400));
      if (hours) hours.textContent = pad(Math.floor((total % 86400) / 3600));
      if (minutes) minutes.textContent = pad(Math.floor((total % 3600) / 60));
      if (seconds) seconds.textContent = pad(total % 60);
      if (total === 0) clearInterval(timer);
    };

    tick();
    timer = setInterval(tick, 1000);
  });
</script>
