---
const benefits = [
  "Напълно безплатно. Без скрити условия.",
  "запис няма. Включи се навреме.",
  "Гледай от всякъде. Нужен ти е само интернет.",
  "Само знания. Няма да ти продаваме нищо.",
];
---

<section class="benefits">
  <img src="/assets/images/benefits-bg.svg" alt="" class="benefits__bg" aria-hidden="true" />
  <div class="container benefits__inner">
    {
      benefits.map((text) => (
        <div class="benefit">
          <span class="benefit__icon">
            <img src="/assets/images/icon-checkbox.svg" alt="" width="28" height="29" />
          </span>
          <p class="benefit__text">{text}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .benefits {
    position: relative;
    background-color: var(--color-gray-40); /* #d8dbde base, shows at the diagonal cut */
    overflow: hidden;
    padding-block: 4em 5em; /* 64 / 80 */
  }
  .benefits__bg {
    position: absolute;
    left: 0;
    top: -14.375em; /* -230px */
    width: 100%;
    height: 32.25em; /* 516px */
    z-index: 0;
  }
  .benefits__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3em;
  }
  .benefit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1em; /* 16px */
    width: 17.25em; /* 276px */
  }
  .benefit__icon {
    display: inline-flex;
    flex-shrink: 0;
  }
  .benefit__icon img {
    width: 1.75em; /* 28px — the SVG already includes its gradient border box */
    height: auto;
  }
  .benefit__text {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 1.5em; /* 24px */
    line-height: 1.2;
    color: var(--color-cream);
    text-transform: uppercase;
    text-align: center;
  }

  @media (max-width: 991px) {
    .benefits {
      background-color: var(--color-dark);
    }
    .benefits__bg {
      display: none;
    }
    .benefits__inner {
      flex-wrap: wrap;
      justify-content: center;
      gap: 2.5em 2em;
    }
    .benefit {
      width: 40%;
    }
  }
  @media (max-width: 479px) {
    .benefit {
      width: 100%;
    }
  }
</style>
