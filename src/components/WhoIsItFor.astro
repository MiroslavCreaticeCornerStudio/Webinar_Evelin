---
const bullets = [
  "Вземаш решения, които влияят на екипа, сделките и растежа на бизнеса.",
  "Трябват ти повече яснота, скорост и хора, които се движат в една посока.",
  "От теб се очаква да държиш екипа фокусиран, дори когато напрежението расте.",
  "Трудно е да пазиш темпо, мотивация и качество едновременно.",
  "Всеки ден си на терен, в срещи, огледи и разговори с клиенти.",
  "Искаш да водиш разговора с повече подготовка, доверие и увереност.",
  "Имаш хъс да се развиваш по-бързо от стандартното работно темпо.",
  "Искаш да се учиш от хора, които вече са минали по този път.",
];
---

<section class="who" id="who-is-it-for">
  <div class="container who__inner">
    <div class="who__image-wrap">
      <img
        src="/assets/images/who-team.webp"
        alt="Екипът на INclusive пред офиса на компанията"
        width="611"
        height="666"
        class="who__image"
        loading="lazy"
      />
    </div>
    <div class="who__content">
      <h2 class="who__heading">Този уебинар е подходящ за теб, ако...</h2>
      <ul class="who__list">
        {
          bullets.map((text) => (
            <li class="who__card">
              <img src="/assets/images/icon-bullet.svg" alt="" width="8" height="16" class="who__bullet" />
              <p class="who__text">{text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .who {
    background-color: var(--color-gray-40); /* #d8dbde */
    padding-block: 5.25em; /* 84px */
  }
  .who__inner {
    display: flex;
    align-items: flex-start;
    gap: 3.875em; /* 62px */
  }
  .who__image-wrap {
    flex-shrink: 0;
    width: 38.1875em; /* 611px */
    /* Pin the photo while the bullet list scrolls past, until the section ends */
    position: sticky;
    top: 2em;
    align-self: flex-start;
  }
  .who__image {
    width: 100%;
    height: auto;
    object-fit: contain;
    transform: rotate(180deg); /* Figma applies rotate-180 to this node; raw export is inverted */
  }
  .who__content {
    display: flex;
    flex-direction: column;
    gap: 3.5em; /* 56px */
    width: 35.9375em; /* 575px */
    flex-shrink: 1;
  }
  .who__heading {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 3em; /* 48px */
    line-height: 1.2;
    color: var(--color-dark);
    text-transform: uppercase;
  }
  .who__list {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
  }
  .who__card {
    display: flex;
    align-items: flex-start;
    gap: 1em; /* 16px */
    padding: 1.25em; /* 20px */
    background-color: var(--color-gray-20); /* #edeff1 */
  }
  .who__bullet {
    width: 0.5em; /* 8px */
    height: 1em; /* 16px */
    flex-shrink: 0;
    margin-top: 0.45em;
  }
  .who__text {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em; /* 18px */
    line-height: 1.3;
    color: var(--color-surface); /* #393c46 */
  }

  @media (max-width: 991px) {
    .who__inner {
      flex-direction: column;
      align-items: center;
      gap: 3em;
    }
    .who__image-wrap {
      width: 100%;
      max-width: 38.1875em;
      position: static; /* no sticky once the layout stacks */
    }
    .who__content {
      width: 100%;
    }
  }
</style>
