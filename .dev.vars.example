# Local dev secrets for the Cloudflare adapter (used by `npm run dev`).
# Copy this file to ".dev.vars" and fill in real values. ".dev.vars" is gitignored
# — NEVER commit real keys. In production these are set in the Cloudflare dashboard
# (Settings → Variables and Secrets), not here.

BREVO_API_KEY=your-brevo-api-key
BREVO_LIST_ID=4

# FUTURE — Zoom Server-to-Server OAuth (for webinar registration):
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_WEBINAR_ID=
